generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  OWNER
  ADMIN
}

enum BookingStatus {
  PENDING
  APPROVED
  PAYMENT_PENDING
  CONFIRMED
  ACTIVE
  REJECTED
  COMPLETED
  CANCELLED
}

enum CarCondition {
  NEW
  GOOD
  AVERAGE
}

enum CarStatus {
  AVAILABLE
  IN_TRIP
  MAINTENANCE
  CLEANING
}

model User {
  id               Int     @id @default(autoincrement())
  name             String
  email            String  @unique
  password         String
  role             Role    @default(CUSTOMER)
  refreshToken     String?
  isVerified       Boolean @default(false)
  stripeCustomerId String?

  bookings      Booking[]
  ownedCars     Car[]          @relation("CarOwner")
  notifications Notification[]
  documents     Document[]
  chatLogs      ChatHistory[]

  ownerVerifications VerificationRequest[] @relation("OwnerVerifications")
  adminVerifications VerificationRequest[] @relation("AdminVerifications")
}

model Car {
  id           Int          @id @default(autoincrement())
  name         String
  brand        String?
  type         String?
  year         Int?
  price        Int
  seats        Int?
  transmission String?
  fuel         String?
  location     String?
  image        String?
  images       String[]
  rcDocument   String?
  condition    CarCondition @default(GOOD)
  isPaused     Boolean      @default(false)
  lat          Float?
  lng          Float?
  availability Boolean      @default(true)
  carStatus    CarStatus    @default(AVAILABLE)
  ownerId      Int?
  owner        User?        @relation("CarOwner", fields: [ownerId], references: [id])

  bookings     Booking[]
  blockedDates BlockedDate[]
  verifications VerificationRequest[] @relation("CarVerifications")
}

model Booking {
  id          Int           @id @default(autoincrement())
  carId       Int
  userId      Int
  startDate   DateTime
  endDate     DateTime
  status      BookingStatus @default(PENDING)
  totalAmount Float?
  paymentId   String?

  rejectionReason String?
  ownerContacted  Boolean @default(false)

  user User @relation(fields: [userId], references: [id])
  car  Car  @relation(fields: [carId], references: [id])
}

model BlockedDate {
  id        Int      @id @default(autoincrement())
  carId     Int
  startDate DateTime
  endDate   DateTime
  reason    String?

  car Car @relation(fields: [carId], references: [id])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Document {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  type          DocType
  fileUrl       String
  extractedData Json?
  isValidated   Boolean  @default(false)
  createdAt     DateTime @default(now())
}

enum DocType {
  LICENSE
  ID_PROOF
}

model ChatHistory {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  sessionId String
  message   String
  isBot     Boolean
  intent    Json?
  createdAt DateTime @default(now())
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  REUPLOAD_REQUIRED
}

enum AdminDocumentType {
  OWNER_ID
  VEHICLE_RC
  INSURANCE
}

model VerificationRequest {
  id              Int                @id @default(autoincrement())
  ownerId         Int
  owner           User               @relation("OwnerVerifications", fields: [ownerId], references: [id])
  vehicleId       Int?
  vehicle         Car?               @relation("CarVerifications", fields: [vehicleId], references: [id])
  documentType    AdminDocumentType
  documentUrl     String
  status          VerificationStatus @default(PENDING)
  
  reviewedBy      Int?
  adminUser       User?              @relation("AdminVerifications", fields: [reviewedBy], references: [id])
  adminNotes      String?
  reviewedAt      DateTime?

  aiAnalysis      Json?
  
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}
