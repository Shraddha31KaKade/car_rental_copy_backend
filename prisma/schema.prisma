generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  OWNER
  ADMIN
}

enum ListingStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum BookingStatus {
  PENDING
  APPROVED
  PAYMENT_PENDING
  CONFIRMED
  ACTIVE
  REJECTED
  COMPLETED
  SETTLED
  CANCELLED
}

enum CarCondition {
  NEW
  GOOD
  AVERAGE
}

enum CarStatus {
  AVAILABLE
  IN_TRIP
  MAINTENANCE
  CLEANING
}

model User {
  id               Int     @id @default(autoincrement())
  name             String
  email            String  @unique
  password         String
  role             Role    @default(CUSTOMER)
  refreshToken     String?
  isVerified       Boolean @default(false)
  stripeCustomerId String?

  bookings      Booking[]
  ownedCars     Car[]          @relation("CarOwner")
  notifications Notification[]
  documents     Document[]
  chatLogs      ChatHistory[]

  ownerVerifications VerificationRequest[] @relation("OwnerVerifications")
  adminVerifications VerificationRequest[] @relation("AdminVerifications")
  reportsMade        Report[] @relation("ReporterRelation")
  reportsReceived    Report[] @relation("ReportedUserRelation")
  adminReviewedCars  Car[]    @relation("AdminCarReviews")
  
  wallet             OwnerWallet?
}

model Car {
  id           Int          @id @default(autoincrement())
  name         String
  brand        String?
  type         String?
  year         Int?
  price        Int
  seats        Int?
  transmission String?
  fuel         String?
  location     String?
  image        String?
  images       String[]
  rcDocument   String?
  condition    CarCondition @default(GOOD)
  isPaused     Boolean      @default(false)
  lat          Float?
  lng          Float?
  availability Boolean      @default(true)
  carStatus    CarStatus    @default(AVAILABLE)
  ownerId      Int?
  owner        User?        @relation("CarOwner", fields: [ownerId], references: [id])
  ownerName    String?
  ownerEmail   String?
  ownerContact String?

  listingStatus   ListingStatus @default(PENDING_APPROVAL)
  adminNotes      String?
  rejectionReason String?
  reviewedAt      DateTime?
  reviewedBy      Int?
  adminUser       User?         @relation("AdminCarReviews", fields: [reviewedBy], references: [id])

  bookings     Booking[]
  blockedDates BlockedDate[]
  verifications VerificationRequest[] @relation("CarVerifications")
  reports      Report[]
}

model Booking {
  id          Int           @id @default(autoincrement())
  carId       Int
  userId      Int
  startDate   DateTime
  endDate     DateTime
  status      BookingStatus @default(PENDING)
  totalAmount Float?
  paymentId   String?

  rejectionReason String?
  ownerContacted  Boolean @default(false)

  user User @relation(fields: [userId], references: [id])
  car  Car  @relation(fields: [carId], references: [id])
  reports Report[]
  escrow  PlatformEscrow?
  
  settledAt DateTime?
  createdAt DateTime  @default(now())
}

model BlockedDate {
  id        Int      @id @default(autoincrement())
  carId     Int
  startDate DateTime
  endDate   DateTime
  reason    String?

  car Car @relation(fields: [carId], references: [id])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Document {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  type          DocType
  fileUrl       String
  extractedData Json?
  isValidated   Boolean  @default(false)
  createdAt     DateTime @default(now())
}

enum DocType {
  LICENSE
  ID_PROOF
}

model ChatHistory {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  sessionId String
  message   String
  isBot     Boolean
  intent    Json?
  createdAt DateTime @default(now())
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  REUPLOAD_REQUIRED
}

enum AdminDocumentType {
  OWNER_ID
  VEHICLE_RC
  INSURANCE
}

model VerificationRequest {
  id              Int                @id @default(autoincrement())
  ownerId         Int
  owner           User               @relation("OwnerVerifications", fields: [ownerId], references: [id])
  vehicleId       Int?
  vehicle         Car?               @relation("CarVerifications", fields: [vehicleId], references: [id])
  documentType    AdminDocumentType
  documentUrl     String
  status          VerificationStatus @default(PENDING)
  
  reviewedBy      Int?
  adminUser       User?              @relation("AdminVerifications", fields: [reviewedBy], references: [id])
  adminNotes      String?
  reviewedAt      DateTime?

  aiAnalysis      Json?
  
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  DISMISS
  ESCALATE
  RESOLVED
}

model Report {
  id               Int           @id @default(autoincrement())
  reporterId       Int
  reportedUserId   Int
  vehicleId        Int?
  bookingId        Int?
  complaintText    String
  attachmentUrls   String[]
  status           ReportStatus  @default(PENDING)
  adminNotes       String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  reporter         User          @relation("ReporterRelation", fields: [reporterId], references: [id])
  reportedUser     User          @relation("ReportedUserRelation", fields: [reportedUserId], references: [id])
  vehicle          Car?          @relation(fields: [vehicleId], references: [id])
  booking          Booking?      @relation(fields: [bookingId], references: [id])
  aiInsight        ReportAIInsight?
}

model ReportAIInsight {
  id                Int      @id @default(autoincrement())
  reportId          Int      @unique
  category          String?
  severity          String?
  summary           String?
  suggestedPriority String?
  createdAt         DateTime @default(now())

  report            Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Inquiry {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?
  mobile    String?
  message   String
  autoReply String?
  createdAt DateTime @default(now())
}

model SystemSettings {
  id                 Int      @id @default(1)
  maintenanceMode    Boolean  @default(false)
  globalAnnouncement String?
  updatedAt          DateTime @updatedAt
}

enum WalletTxType {
  CREDIT
  DEBIT
  REFUND
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

model PlatformEscrow {
  id          Int      @id @default(autoincrement())
  bookingId   Int      @unique
  booking     Booking  @relation(fields: [bookingId], references: [id])
  totalAmount Float
  platformFee Float
  ownerShare  Float
  createdAt   DateTime @default(now())
}

model OwnerWallet {
  id           Int      @id @default(autoincrement())
  ownerId      Int      @unique
  owner        User     @relation(fields: [ownerId], references: [id])
  balance      Float    @default(0)
  updatedAt    DateTime @updatedAt
  transactions WalletTransaction[]
  payouts      Payout[]
}

model WalletTransaction {
  id        Int          @id @default(autoincrement())
  walletId  Int
  wallet    OwnerWallet  @relation(fields: [walletId], references: [id])
  type      WalletTxType
  amount    Float
  bookingId Int?
  createdAt DateTime     @default(now())
}

model Payout {
  id         Int          @id @default(autoincrement())
  walletId   Int
  wallet     OwnerWallet  @relation(fields: [walletId], references: [id])
  amount     Float
  status     PayoutStatus @default(PENDING)
  gatewayRef String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}
